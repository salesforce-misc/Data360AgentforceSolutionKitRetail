# This file is used for Git repositories to specify intentionally untracked files that Git should ignore. 
# If you are not using git, you can delete this file. For more information see: https://git-scm.com/docs/gitignore
# For useful gitignore templates see: https://github.com/github/gitignore

# Salesforce cache
.sf/
.sfdx/
.localdevserver/
deploy-options.json

# LWC VSCode autocomplete
**/lwc/jsconfig.json

# LWC Jest coverage reports
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# ApexPMD cache
.pmdCache

# Eslint cache
.eslintcache

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Local environment variables
.env

# Python Salesforce Functions
**/__pycache__/
**/.venv/
**/venv/

# --- Credential leak prevention (Data360 installer) ---
# These filenames have been observed in production incidents where an agent
# or coordinator wrote OAuth tokens / session credentials to the repo root.
# They are forbidden by .claude/agents/data360-retail-installer/AGENT.md's
# authentication rule, but listing them here is a mechanical safety net:
# even if a process writes one despite the rule, git refuses to commit it.
# DO NOT remove these patterns. If a future skill needs to share creds
# between steps, use `sf org display` at point-of-use — never a file on disk.
sf-env.sh
sf-auth-helper.sh
sf-wrapper.sh
sf_auto_login.py
sf_auth_workaround.py
org_creds.json
frontdoor_url.txt
sfdx_auth*.txt
access_token*.txt
auth.txt
*.sfdxAuthUrl

# Playwright MCP traces — may contain captured cookies / session IDs
.playwright-mcp/
